FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

# Создаём непривилегированного пользователя
RUN groupadd -r appuser && useradd -r -g appuser -d /app -s /sbin/nologin appuser

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Копируем только агентский код и скрипты (не весь репозиторий)
COPY agents/ ./agents/
COPY docker-entrypoint-agent.sh .
COPY agent-healthcheck.sh .

RUN chmod +x /app/docker-entrypoint-agent.sh /app/agent-healthcheck.sh && \
    chown -R appuser:appuser /app

USER appuser

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD ["/app/agent-healthcheck.sh"]

ENTRYPOINT ["/app/docker-entrypoint-agent.sh"]
