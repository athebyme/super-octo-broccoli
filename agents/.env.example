# WB Seller Platform — Agent Configuration
# Скопируйте в .env и заполните значения

# ── Платформа ──────────────────────────────────────────────
PLATFORM_URL=http://localhost:5000
AGENT_ID=<uuid агента из БД>
AGENT_API_KEY=<api ключ, полученный при регистрации>

# ── LLM Провайдер ─────────────────────────────────────────
# Выберите один: "claude" или "gemini"
LLM_PROVIDER=claude

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# Google Gemini
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash

# ── Рантайм ───────────────────────────────────────────────
AGENT_POLL_INTERVAL=5
AGENT_HEARTBEAT_INTERVAL=30
LOG_LEVEL=INFO
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
