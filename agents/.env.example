# WB Seller Platform — Agent Configuration
# Скопируйте в .env и заполните значения

# ── Платформа ──────────────────────────────────────────────
PLATFORM_URL=http://localhost:5000
AGENT_ID=<uuid агента из БД>
AGENT_API_KEY=<api ключ, полученный при регистрации>

# ── LLM Провайдер (основной) ────────────────────────────────
# Выберите один: "cloudru" | "claude" | "gemini" | "openai_compat"
LLM_PROVIDER=cloudru

# Cloud.ru Foundation Models (GPT-OSS-120B — основной, дешёвый и быстрый)
CLOUDRU_API_KEY=<ключ Cloud.ru>
CLOUDRU_BASE_URL=https://foundation-models.api.cloud.ru/v1/
CLOUDRU_MODEL=openai/gpt-oss-120b

# ── Fallback LLM (для сложных агентов) ──────────────────────
# Агенты с use_fallback_llm=True (auto-importer, card-doctor, price-optimizer)
# будут использовать этот провайдер вместо основного.
# Оставьте пустым чтобы все агенты работали на основном провайдере.
FALLBACK_LLM_PROVIDER=claude
FALLBACK_LLM_MODEL=claude-haiku-4-5-20251001

# Anthropic Claude (нужен если FALLBACK_LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# Google Gemini
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash

# Любой OpenAI-совместимый API (vLLM, Ollama, LM Studio, Together, Groq)
# OPENAI_COMPAT_API_KEY=...
# OPENAI_COMPAT_BASE_URL=http://localhost:8000/v1
# OPENAI_COMPAT_MODEL=meta-llama/Llama-3-70b

# ── Рантайм ───────────────────────────────────────────────
AGENT_POLL_INTERVAL=5
AGENT_HEARTBEAT_INTERVAL=30
LOG_LEVEL=INFO
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
