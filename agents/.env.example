# WB Seller Platform — Agent Configuration
# Скопируйте в .env и заполните значения

# ── Платформа ──────────────────────────────────────────────
PLATFORM_URL=http://localhost:5000
AGENT_ID=<uuid агента из БД>
AGENT_API_KEY=<api ключ, полученный при регистрации>

# ── LLM Провайдер ─────────────────────────────────────────
# Выберите один: "claude" | "gemini" | "cloudru" | "openai_compat"
LLM_PROVIDER=claude

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# Google Gemini
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash

# Cloud.ru Foundation Models
# CLOUDRU_API_KEY=...
# CLOUDRU_BASE_URL=https://api.foundation-models.ru/v1
# CLOUDRU_MODEL=deepseek-ai/DeepSeek-V3

# Любой OpenAI-совместимый API (vLLM, Ollama, LM Studio, Together, Groq)
# OPENAI_COMPAT_API_KEY=...
# OPENAI_COMPAT_BASE_URL=http://localhost:8000/v1
# OPENAI_COMPAT_MODEL=meta-llama/Llama-3-70b

# ── Рантайм ───────────────────────────────────────────────
AGENT_POLL_INTERVAL=5
AGENT_HEARTBEAT_INTERVAL=30
LOG_LEVEL=INFO
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
