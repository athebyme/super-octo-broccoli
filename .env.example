# ============================================
# Seller Platform Configuration
# ============================================

# Домен (Caddy автоматически получит Let's Encrypt сертификат)
# Пример: DOMAIN=seller.my-domain.ru
DOMAIN=

# Порты
SELLER_PORT=5001
CALCULATOR_PORT=5000

# Безопасность (ОБЯЗАТЕЛЬНО СМЕНИТЕ В ПРОДАКШЕНЕ!)
# Сгенерируйте надёжный ключ командой: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
APP_SECRET_KEY=

# База данных - ВАЖНО: путь должен указывать на volume
DATABASE_URL=sqlite:////app/data/seller_platform.db

# Шифрование API ключей (оставьте пустым для генерации)
ENCRYPTION_KEY=

# Администратор по умолчанию (ОБЯЗАТЕЛЬНО СМЕНИТЕ ПАРОЛЬ!)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Публичный URL сервера (для раздачи фото в WB)
# Должен совпадать с DOMAIN. WB скачивает фото по этим URL
# Пример: PUBLIC_BASE_URL=https://seller.my-domain.ru
PUBLIC_BASE_URL=

# HTTPS / SSL
# Оставьте пустыми чтобы авто-генерировать self-signed сертификат
SSL_CERT_PATH=
SSL_KEY_PATH=
# CN для self-signed сертификата (по умолчанию: seller-platform)
SSL_COMMON_NAME=
# Дополнительные IP и домены для сертификата (через запятую)
# Пример: SSL_SAN_IPS=123.45.67.89,my-domain.ru
SSL_SAN_IPS=

# ============================================
# AI Agents (docker compose --profile agents up)
# ============================================
# Для запуска агентов нужно:
# 1. Запустить платформу: docker compose up -d
# 2. Зайти в UI → /agents → Активировать нужного агента
# 3. Скопировать AGENT_ID и AGENT_API_KEY сюда
# 4. Запустить агента: docker compose --profile agents up -d agent-seo-writer

# LLM провайдер
LLM_PROVIDER=cloudru
CLOUDRU_API_KEY=
CLOUDRU_BASE_URL=https://foundation-models.api.cloud.ru/v1/
CLOUDRU_MODEL=openai/gpt-oss-120b

# Agent credentials (из UI)
AGENT_SEO_WRITER_ID=
AGENT_SEO_WRITER_KEY=
AGENT_CATEGORY_MAPPER_ID=
AGENT_CATEGORY_MAPPER_KEY=
AGENT_AUTO_IMPORTER_ID=
AGENT_AUTO_IMPORTER_KEY=
AGENT_CARD_DOCTOR_ID=
AGENT_CARD_DOCTOR_KEY=
AGENT_PRICE_OPTIMIZER_ID=
AGENT_PRICE_OPTIMIZER_KEY=

# Fallback LLM (для сложных агентов)
# FALLBACK_LLM_PROVIDER=claude
# FALLBACK_LLM_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=
