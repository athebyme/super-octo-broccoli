# ============================================
# Seller Platform Configuration
# ============================================

# Домен (Caddy автоматически получит Let's Encrypt сертификат)
# Пример: DOMAIN=seller.my-domain.ru
DOMAIN=

# Порты
SELLER_PORT=5001
CALCULATOR_PORT=5000

# Безопасность (ОБЯЗАТЕЛЬНО СМЕНИТЕ В ПРОДАКШЕНЕ!)
# Сгенерируйте надёжный ключ командой: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
APP_SECRET_KEY=

# PostgreSQL
POSTGRES_USER=seller
POSTGRES_PASSWORD=
POSTGRES_DB=seller_platform
# DATABASE_URL формируется автоматически в docker-compose.yml
# Для ручного запуска без Docker:
# DATABASE_URL=postgresql://seller:password@localhost:5432/seller_platform

# Шифрование API ключей (оставьте пустым для генерации)
ENCRYPTION_KEY=

# Администратор по умолчанию (ОБЯЗАТЕЛЬНО СМЕНИТЕ ПАРОЛЬ!)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Публичный URL сервера (для раздачи фото в WB)
# Должен совпадать с DOMAIN. WB скачивает фото по этим URL
# Пример: PUBLIC_BASE_URL=https://seller.my-domain.ru
PUBLIC_BASE_URL=

# HTTPS / SSL
# Оставьте пустыми чтобы авто-генерировать self-signed сертификат
SSL_CERT_PATH=
SSL_KEY_PATH=
# CN для self-signed сертификата (по умолчанию: seller-platform)
SSL_COMMON_NAME=
# Дополнительные IP и домены для сертификата (через запятую)
# Пример: SSL_SAN_IPS=123.45.67.89,my-domain.ru
SSL_SAN_IPS=
