# Docker Compose Environment Variables
# Скопируйте этот файл в .env и настройте значения

# Seller Platform (порт 5001)
SELLER_PORT=5001
SECRET_KEY=your-secret-key-here-change-in-production

# ВАЖНО: Сгенерируйте ключ шифрования для API ключей WB
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key-here

# WB Calculator (порт 5000)
CALCULATOR_PORT=5000
APP_SECRET_KEY=wb-calculator-secret-change-in-production

# База данных (по умолчанию SQLite в ./data/)
# DATABASE_URL=sqlite:////app/data/seller_platform.db

# Администратор (ОБЯЗАТЕЛЬНО!)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production

# ══════════════════════════════════════════════════════════════
# AI Agents (docker compose --profile agents up -d agent-seo-writer)
# ══════════════════════════════════════════════════════════════

# LLM провайдер (cloudru | claude | gemini | openai_compat)
LLM_PROVIDER=cloudru
CLOUDRU_API_KEY=
CLOUDRU_BASE_URL=https://foundation-models.api.cloud.ru/v1/
CLOUDRU_MODEL=openai/gpt-oss-120b

# SEO Writer Agent (получите ID и KEY в UI: /agents → Активировать)
AGENT_SEO_WRITER_ID=
AGENT_SEO_WRITER_KEY=

# Category Mapper Agent
AGENT_CATEGORY_MAPPER_ID=
AGENT_CATEGORY_MAPPER_KEY=

# Auto Importer Agent
AGENT_AUTO_IMPORTER_ID=
AGENT_AUTO_IMPORTER_KEY=

# Card Doctor Agent
AGENT_CARD_DOCTOR_ID=
AGENT_CARD_DOCTOR_KEY=

# Price Optimizer Agent
AGENT_PRICE_OPTIMIZER_ID=
AGENT_PRICE_OPTIMIZER_KEY=

# Fallback LLM (для сложных агентов: auto-importer, card-doctor, price-optimizer)
# FALLBACK_LLM_PROVIDER=claude
# FALLBACK_LLM_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=sk-ant-...
